# Fahamu Shamba Environment Variables

# OpenWeatherMap API Key (for real-time weather data)
# Get your free API key from: https://openweathermap.org/api
OPENWEATHER_API_KEY=your_api_key_here

# Database Configuration (auto-detected)
# DATABASE_URL=postgres://... (for production - set by hosting platform)

# Server Configuration
PORT=5000
NODE_ENV=development

# SMS Configuration (optional - for weather alerts)
# TWILIO_ACCOUNT_SID=your_account_sid
# TWILIO_AUTH_TOKEN=your_auth_token
# TWILIO_PHONE_NUMBER=+1234567890

# Or use Safaricom SMS
# SAFARICOM_CONSUMER_KEY=your_consumer_key
# SAFARICOM_CONSUMER_SECRET=your_consumer_secret
# SAFARICOM_SHORTCODE=your_shortcode

# Email Configuration (optional - for admin notifications)
# EMAIL_SERVICE=gmail
# EMAIL_USER=your_email@gmail.com
# EMAIL_PASSWORD=your_app_password
