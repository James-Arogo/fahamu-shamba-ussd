# Fahamu Shamba USSD & SMS Environment Configuration
# Copy this file to .env and fill in your credentials

# ==================== SERVER CONFIG ====================
NODE_ENV=development
PORT=5000

# ==================== DATABASE (Vercel auto-configures) ====================
# DATABASE_URL=postgresql://user:pass@host/db  # Set for Vercel Postgres

# ==================== USSD/SMS PROVIDERS ====================

## TWILIO (Recommended for testing - works on localhost)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+1234567890
USSD_PROVIDER=twilio

## AFRICA'S TALKING (Production - Kenyan USSD)
# AFRICASTALKING_USERNAME=your_sandbox_username
# AFRICASTALKING_API_KEY=ATSxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# AFRICASTALKING_WEBHOOK_TOKEN=your_shared_webhook_secret
# USSD_SERVICE_CODE=*123#
# USSD_PROVIDER=africastalking

## SAFARICOM DARAJA (Alternative SMS)
# SAFARICOM_CONSUMER_KEY=your_consumer_key
# SAFARICOM_CONSUMER_SECRET=your_consumer_secret
# SAFARICOM_SHORTCODE=your_shortcode
# SMS_PROVIDER=safaricom

# ==================== SMS FALLBACK ====================
SMS_PROVIDER=auto  # auto, twilio, safaricom

# ==================== WEATHER API (Optional) ====================
OPENWEATHER_API_KEY=your_openweather_key

# ==================== ADMIN SETUP (Optional) ====================
ADMIN_EMAIL=admin@fahamushamba.com
ADMIN_PASSWORD=your_secure_password_here
ADMIN_DEFAULT_EMAIL=cjoarogo@gmail.com
ADMIN_DEFAULT_PASSWORD=Jemo@721

# ==================== EMAIL/OTP DELIVERY ====================
# Preferred (Gmail)
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_password
EMAIL_FROM=your_email@gmail.com
# Optional SMTP alternative
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your_email@gmail.com
# SMTP_PASSWORD=your_app_password

# ==================== PRODUCTION ====================
ALLOWED_ORIGINS=https://yourdomain.com,http://localhost:3000
